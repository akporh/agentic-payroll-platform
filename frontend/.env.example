# Frontend environment variables — copy to .env.local for local development.
# Never commit .env.local or .env.production to git.

# Base URL of the backend API.
# Leave EMPTY in development — Vite's dev-server proxy rewrites /api → http://localhost:8000/api/v1.
# In production (Vercel) set this to your Render backend URL in the Vercel dashboard.
VITE_API_URL=
